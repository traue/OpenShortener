# ── Database ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=openshortener
DB_USER=root
DB_PASS=

# ── Application ──────────────────────────────────────────────
APP_BASE_URL=https://short.opensource.dev.br
CORS_ORIGIN=*
SESSION_SECURE=true

# ── Captcha (Cloudflare Turnstile) ───────────────────────────
# Set CAPTCHA_ENABLED=0 to disable entirely. When enabled, the captcha
# only kicks in after CAPTCHA_ANON_THRESHOLD anonymous shortens (per IP)
# or CAPTCHA_USER_THRESHOLD logged-in shortens (per user) within
# CAPTCHA_WINDOW_HOURS. Get the keys at https://dash.cloudflare.com →
# Turnstile → Add site. The site_key is public (rendered in the browser);
# the secret_key must stay on the server.
CAPTCHA_ENABLED=0
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
CAPTCHA_ANON_THRESHOLD=5
CAPTCHA_USER_THRESHOLD=10
CAPTCHA_WINDOW_HOURS=24
